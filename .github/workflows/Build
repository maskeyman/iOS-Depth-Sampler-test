name: Build IPA

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: macos-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Build Xcode Project
        run: |
          xcodebuild clean build \
            -workspace "iOS-Depth-Sampler.xcworkspace" \
            -scheme "iOS-Depth-Sampler" \
            -configuration Release \
            -sdk iphoneos \
            CODE_SIGN_IDENTITY="" \
            CODE_SIGNING_REQUIRED=NO \
            CODE_SIGNING_ALLOWED=NO \
            DSTROOT=$(pwd)/build \
            INSTALL_PATH=/

      - name: Package into IPA
        run: |
          mkdir -p Payload
          mv build/iOS-Depth-Sampler.app Payload/
          zip -r iOS-Depth-Sampler.ipa Payload

      - name: Upload IPA Artifact
        uses: actions/upload-artifact@v4
        with:
          name: iOS-Depth-Sampler-IPA
          path: iOS-Depth-Sampler.ipa
